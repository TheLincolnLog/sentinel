{
  "manifest_version": 3,
  "name": "Sentinel",
  "version": "3.0",
  "description": "Real-time manipulation, toxicity, and misinformation detector",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ]
}
