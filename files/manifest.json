{
  "manifest_version": 3,
  "name": "Sentinel",
  "version": "1.0",
  "description": "Real-time manipulation, toxicity, and misinformation detector",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8000/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sentinel"
  }
}
